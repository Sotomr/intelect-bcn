# Copia a .env (no el pugis al repositori)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Zona horària per a la finestra «avui + N dies»
# TIMEZONE=Europe/Madrid

# Finestra de dies a incloure al digest (per defecte 7)
# WINDOW_DAYS=7

# Màxim d’entrades per institució dins cada àmbit
# MAX_EVENTS_PER_INSTITUTION=12

# Màxim d’esdeveniments de la capa «base» (Guia filtrada); 0 = sense límit
# MAX_BASE_EVENTS=18

# CSV oficial Open Data BCN (Guia Barcelona)
# GUIA_CSV_URL=https://opendata-ajuntament.barcelona.cat/data/dataset/...

# Neteja del registre de claus «ja vistes» (novetats); per defecte 120 dies
# SEEN_PRUNE_DAYS=120

# Agregador RSS (IEC, SCM, MACBA, Ateneu, Hangar, Mies… — veure src/scrapers/rss_feeds.py)
# RSS_ENABLED=1
# RSS_MAX_PER_FEED=25

# Afegir bloc «novetats» respecte al snapshot anterior (1 sí, 0 no)
# APPEND_NOVELTIES=1

# Només generar text i snapshot, sense Telegram
# DRY_RUN=1
# SKIP_TELEGRAM=1

# URLs (per defecte CCCB calendari + CIDOB activitats)
# CCCB_CALENDAR_URL=https://www.cccb.org/ca/calendari
# CIDOB_ACTIVITIES_URL=https://www.cidob.org/actividades
