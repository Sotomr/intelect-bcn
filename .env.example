# Copia a .env (no el pugis al repositori)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Zona horària per a la finestra «avui + N dies»
# TIMEZONE=Europe/Madrid

# Finestra de dies a incloure al digest (per defecte 7)
# WINDOW_DAYS=7

# Màxim d’entrades per institució dins cada àmbit
# MAX_EVENTS_PER_INSTITUTION=12

# Màxim d’esdeveniments de la capa «base» (Guia filtrada); 0 = sense límit
# (per defecte 32 perquè es vegin més institucions abans del límit de Telegram)
# MAX_BASE_EVENTS=32

# CSV oficial Open Data BCN (Guia Barcelona)
# GUIA_CSV_URL=https://opendata-ajuntament.barcelona.cat/data/dataset/...
# Timeout lectura CSV (segons, 30–300); per defecte 120 (evita bloquejos de 5 min a Actions)
# GUIA_CSV_TIMEOUT=120

# Timeout lectura per cada feed RSS (connexió 15s, lectura per defecte 55s)
# RSS_HTTP_READ_TIMEOUT=55

# Neteja del registre de claus «ja vistes» (novetats); per defecte 120 dies
# SEEN_PRUNE_DAYS=120

# Agregador RSS (IEC, SCM, MACBA, Ateneu, Ara Cultura, Betevé, Directa, Rezero… — veure src/scrapers/rss_feeds.py)
# RSS_ENABLED=1
# RSS_MAX_PER_FEED=25

# Afegir bloc «novetats» respecte al snapshot anterior (1 sí, 0 no)
# APPEND_NOVELTIES=1

# Només generar text i snapshot, sense Telegram
# DRY_RUN=1
# SKIP_TELEGRAM=1

# Timeout lectura HTTP (CCCB/CIDOB); connexió 25s, lectura per defecte 120s
# HTTP_READ_TIMEOUT=120
# Reintents GET (504 gateway); per defecte 4 (valors alts + backoff llarg allarguen el job diversos minuts)
# HTTP_MAX_ATTEMPTS=4

# Digest editorial: nombre de destacats i màxim per font (evita monopol CCCB)
# DIGEST_HIGHLIGHT_COUNT=7
# DIGEST_MAX_PER_SOURCE=3

# URLs (per defecte CCCB calendari + CIDOB activitats)
# CCCB_CALENDAR_URL=https://www.cccb.org/ca/calendari
# CIDOB_ACTIVITIES_URL=https://www.cidob.org/actividades
